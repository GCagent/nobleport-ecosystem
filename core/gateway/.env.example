# NoblePort MCP Gateway configuration
DATABASE_URL=postgresql://noble:noble@postgres:5432/noble
REDIS_URL=redis://redis:6379/0

# Governance
MAX_MESSAGE_CHARS=2000
RATE_LIMIT_PER_MIN=20
CACHE_TTL_S=60

# KPI snapshot worker
KPI_INTERVAL_S=600
ENABLE_KPI_WORKER=true

# Tool execution: false = STAGED stub executor; true = call real agent endpoints
USE_HTTP_EXECUTOR=false
TOOL_TIMEOUT_S=10

# Admin token required to engage/release the kill switch
ADMIN_TOKEN=change-me

LOG_LEVEL=INFO
