# Stephanie Endpoint Configuration
# Copy to .env and fill in real values before running.

# API key for Bearer auth on /api/v1/stephanie/execute
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
STEPHANIE_API_KEY=replace-with-long-random-api-key

# HMAC secret for webhook signature validation
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=replace-with-webhook-secret

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
